#!/usr/bin/env bash
# Display image in terminal — kitty protocol with tmux passthrough, sixel fallback
# Usage: ./show.sh [image] [max_width]

IMAGE="${1?no image provided}"
MAX_WIDTH="${2:-800}"

if [[ ! -f "$IMAGE" ]]; then
    echo "File not found: $IMAGE" >&2
    exit 1
fi

is_kitty() { [[ -n "$KITTY_WINDOW_ID" || "$TERM" == *kitty* || "$TERM_PROGRAM" == *kitty* ]]; }

if [[ -n "$TMUX" ]] && is_kitty; then
    # Enable per-pane passthrough
    tmux set-option -p allow-passthrough on 2>/dev/null || true
    # Wrap each kitty APC chunk (ESC _ ... ESC \) in tmux DCS passthrough.
    # Inside DCS passthrough every ESC must be doubled.
    timg -pk --compress -W "$MAX_WIDTH" "$IMAGE" | \
        perl -0777 -pe 's/\x1b_(.*?)\x1b\\/\x1bPtmux;\x1b\x1b_$1\x1b\x1b\\\x1b\\/gs'
elif is_kitty; then
    timg -pk --compress -W "$MAX_WIDTH" "$IMAGE"
else
    img2sixel -w "$MAX_WIDTH" "$IMAGE"
fi
